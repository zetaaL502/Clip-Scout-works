modules = ["nodejs-24", "python3.11", "python3"]

  [[artifacts]]
  id = "artifacts/clipscout"

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "Project"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start application"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start frontend"

  [[workflows.workflow]]
  name = "Start application"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "PORT=8080 NODE_ENV=development pnpm --filter @workspace/api-server run dev"
  waitForPort = 8080

  [workflows.workflow.metadata]
  outputType = "console"

  [[workflows.workflow]]
  name = "Start frontend"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "PORT=3001 BASE_PATH=/ pnpm --filter @workspace/clipscout run dev"
  waitForPort = 3001

  [workflows.workflow.metadata]
  outputType = "webview"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [userenv]

  [userenv.shared]
  AI_INTEGRATIONS_GEMINI_BASE_URL = "https://generativelanguage.googleapis.com"
PEXELS_API_KEY = "B3naJ4sFU2508yTY9vfRdsBFyXz29jol4CVMIgwtZM9z8UUvQZAPqYSk"
PIXABAY_API_KEY = "55220373-471236b9bb8ca7b1f3acab62c"
ASSEMBLYAI_API_KEY = "2b187e10a7e343b2bbaaeeaf533afb1a"

  [nix]
  channel = "stable-25_05"
  