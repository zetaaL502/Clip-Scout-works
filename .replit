modules = ["nodejs-24", "python3.11", "python3"]

  [[artifacts]]
  id = "artifacts/clipscout"

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [userenv]

  [userenv.shared]
  AI_INTEGRATIONS_GEMINI_BASE_URL = "https://generativelanguage.googleapis.com"
PEXELS_API_KEY = "B3naJ4sFU2508yTY9vfRdsBFyXz29jol4CVMIgwtZM9z8UUvQZAPqYSk"
